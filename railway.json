{
    "build":  {
                  "builder":  "NIXPACKS"
              },
    "deploy":  {
                   "startCommand":  "python manage.py migrate --noinput \u0026\u0026 gunicorn parking_system.wsgi --bind 0.0.0.0:$PORT --workers 4 --timeout 120",
                   "healthcheckPath":  "/",
                   "restartPolicyType":  "ON_FAILURE",
                   "restartPolicyMaxRetries":  10
               }
}
